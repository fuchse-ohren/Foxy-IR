{
  "manifest_version": 2,
  "name": "Foxy IR",
  "version": "1.2",
  "description": "Nature RemoのCloud API経由で家電を操作するFirefoxアドオンです。",
  "icons": {
    "64": "icon_64.png"
  },
  "permissions": ["storage", "tabs", "https://api.nature.global/*"],
  "background": {
    "scripts": ["src/background.js"]
  },
  "browser_action": {
    "default_title": "Foxy IR",
    "default_popup": "src/popup.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "browser_style": false
  },
  "applications": {
    "gecko": {
      "id": "foxy-ir@example.com"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{e53f94b1-49b2-4451-a6c3-750ba8760e28}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
